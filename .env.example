# [v1] dokkaebi-ai 환경변수 예시 (base-pipeline/kys/v1, 2026-06-10)
# 복사: cp .env.example .env  (접두사 DOKKAEBI_)

DOKKAEBI_ENV=local
DOKKAEBI_LOG_LEVEL=INFO

# --- LLM provider 선택 (교체 지점) ---
DOKKAEBI_LLM_PROVIDER=mock          # mock | upstage | openai  (실서비스=upstage)
#  ↓ 실제 LLM(Upstage Solar) 쓸 때: provider=upstage + 아래 채우기
DOKKAEBI_LLM_BASE_URL=https://api.upstage.ai/v1   # OpenAI면 https://api.openai.com/v1
DOKKAEBI_LLM_MODEL=solar-pro                       # openai면 gpt-4o-mini 등
DOKKAEBI_LLM_API_KEY=          # Upstage/OpenAI API 키 (실제 키는 .env 에만!)
DOKKAEBI_LLM_TEMPERATURE=0.7
DOKKAEBI_LLM_MAX_TOKENS=512

# --- LLM 동시성/재시도 (API 호출부 안전) ---
DOKKAEBI_LLM_SEMAPHORE=8            # 동시 LLM 호출 상한(세마포어 개수)
DOKKAEBI_LLM_MAX_RETRIES=5         # 429 재시도 횟수
DOKKAEBI_LLM_BACKOFF_BASE=0.5     # 지수 백오프 base(초)
DOKKAEBI_LLM_BACKOFF_MAX=20       # 백오프 상한(초)
DOKKAEBI_LLM_TIMEOUT=30           # 호출 타임아웃(초)

# --- TourAPI (국문관광정보 — 노드 데이터) ---
# 키 없으면 mock 종로 노드로 구동. 실제: 공공데이터포털 "일반 인증키(Decoding)" 사용
DOKKAEBI_TOURAPI_SERVICE_KEY=
DOKKAEBI_TOURAPI_BASE_URL=http://apis.data.go.kr/B551011/KorService2

# --- 시나리오 생성 (거리순 v0) ---
DOKKAEBI_SCENARIO_NODE_COUNT=5         # 기억석 조각 수 = 방문 장소 수
DOKKAEBI_SCENARIO_DEFAULT_RADIUS_M=2000

# --- 임베딩 (의미검색 ②③ — 나중. mock이면 키 불필요) ---
DOKKAEBI_EMBED_PROVIDER=mock          # mock | upstage | openai
DOKKAEBI_EMBED_BASE_URL=https://api.upstage.ai/v1
DOKKAEBI_EMBED_MODEL=solar-embedding-1-large
DOKKAEBI_EMBED_API_KEY=               # 실제 키는 .env 에만!
DOKKAEBI_EMBED_DIM=4096               # 모델 차원에 맞춰(solar-embedding-1-large=4096)

# --- 캐시 (대사·노드 상세) ---
DOKKAEBI_CACHE_BACKEND=memory     # memory(로컬) | redis(compose·배포, 공유·영속)
DOKKAEBI_REDIS_URL=redis://localhost:6379
DOKKAEBI_CACHE_TTL_S=86400        # 대사 캐시 TTL(초)
DOKKAEBI_TOURAPI_CACHE_TTL_S=604800  # 노드 상세(overview) 캐시 TTL(거의 정적)

# --- 지역 인메모리 캐시 ---
DOKKAEBI_REGION_CACHE_MAX=8       # 동시 상주 지역 수(LRU)
